{
  "name": "solana-agent-firewall",
  "version": "0.1.0",
  "description": "Pre-sign transaction firewall for Solana agents with CLI and MCP surfaces.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winsznx/solana-agent-firewall.git"
  },
  "bugs": {
    "url": "https://github.com/winsznx/solana-agent-firewall/issues"
  },
  "homepage": "https://github.com/winsznx/solana-agent-firewall#readme",
  "bin": {
    "firewall": "./dist/cli.js",
    "solana-agent-firewall-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "skill",
    "agents",
    "commands",
    "scripts",
    "test/fixtures",
    "README.md",
    "LICENSE",
    "install.sh"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "fetch:fixtures": "tsx scripts/fetch-fixtures.ts",
    "firewall": "node dist/cli.js",
    "mcp": "node dist/mcp.js",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:fixtures": "vitest run test/fixture-manifest.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
